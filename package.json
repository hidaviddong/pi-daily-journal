{
  "name": "pi-daily-journal",
  "version": "0.3.0",
  "description": "A pi extension that summarizes your pi coding sessions from a given day into a natural-language diary entry.",
  "keywords": [
    "pi-package",
    "pi-coding-agent",
    "pi-extension",
    "extension",
    "journal",
    "diary",
    "sessions"
  ],
  "license": "MIT",
  "author": "hidaviddong",
  "files": [
    "index.ts",
    "daily-journal.example.json",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "release": "bumpp"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hidaviddong/pi-daily-journal.git"
  },
  "pi": {
    "extensions": [
      "./index.ts"
    ]
  },
  "peerDependencies": {
    "@earendil-works/pi-coding-agent": "*"
  },
  "devDependencies": {
    "bumpp": "^12.0.0"
  }
}
